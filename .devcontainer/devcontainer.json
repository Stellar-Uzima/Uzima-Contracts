{
  "name": "Uzima Contracts - Soroban Development",
  "image": "mcr.microsoft.com/devcontainers/rust:1.92-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "vadimcn.vscode-lldb",
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "github.copilot",
        "github.copilot-chat",
        "ms-azuretools.vscode-docker",
        "editorconfig.editorconfig",
        "redhat.vscode-yaml",
        "timonwong.shellcheck"
      ],
      "settings": {
        "rust-analyzer.cargo.target": "wasm32-unknown-unknown",
        "rust-analyzer.checkOnSave.command": "clippy",
        "editor.formatOnSave": true,
        "rust-analyzer.rustfmt.extraArgs": ["--edition", "2021"],
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        }
      }
    }
  },

  "containerEnv": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always",
    "SOROBAN_NETWORK": "local"
  },

  "postCreateCommand": "rustup override set 1.92.0 && rustup target add wasm32-unknown-unknown && rustup component add rustfmt clippy rust-src && cargo install --locked soroban-cli@21.7.7 && cargo install cargo-watch cargo-audit || true && apt-get update && apt-get install -y shellcheck bc jq && rm -rf /var/lib/apt/lists/* && cargo fetch && cargo build --all-targets 2>&1 | tail -20",

  "remoteUser": "vscode",
  "mounts": [
    "source=${localWorkspaceFolder}/.soroban,target=/home/vscode/.soroban,type=bind",
    "source=${localWorkspaceFolder}/target,target=${containerWorkspaceFolder}/target,type=bind"
  ],

  "portsAttributes": {
    "8000": {
      "label": "Stellar Local RPC",
      "onAutoForward": "notify"
    }
  }
}
