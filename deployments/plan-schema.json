{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Uzima Deployment Plan",
  "description": "Schema for deployment dry-run plans generated by deploy_dryrun.sh",
  "version": "1.0.0",
  "type": "object",
  "required": ["plan_version", "generated_at", "dry_run", "network"],
  "properties": {
    "plan_version": {
      "type": "string",
      "description": "Version of the plan format",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the plan was generated"
    },
    "dry_run": {
      "type": "boolean",
      "description": "Always true for dry-run plans",
      "const": true
    },
    "network": {
      "type": "object",
      "required": ["name", "passphrase", "rpc_url"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["local", "testnet", "futurenet", "mainnet"],
          "description": "Target network name"
        },
        "passphrase": {
          "type": "string",
          "description": "Stellar network passphrase"
        },
        "rpc_url": {
          "type": "string",
          "format": "uri",
          "description": "Soroban RPC endpoint URL"
        }
      }
    },
    "contract": {
      "type": "object",
      "description": "Single-contract plan (present when not using --all)",
      "required": ["name", "wasm_path"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Contract name (directory under contracts/)"
        },
        "wasm_path": {
          "type": "string",
          "description": "Relative path to the compiled WASM artifact"
        },
        "wasm_size_bytes": {
          "type": ["integer", "null"],
          "description": "Size of the WASM file in bytes (null if not found)"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of contract dependencies"
        }
      }
    },
    "total_contracts": {
      "type": "integer",
      "description": "Total number of contracts (present in --all mode)"
    },
    "deployment_order": {
      "type": "array",
      "description": "Ordered list of contracts to deploy (present in --all mode)",
      "items": {
        "$ref": "#/$defs/deployment_step"
      }
    },
    "build": {
      "type": "object",
      "description": "Build status for the contract",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["skipped", "required", "completed"],
          "description": "Whether a build is needed before deployment"
        },
        "check": {
          "type": "string",
          "enum": ["passed", "wasm_not_found", "stale"],
          "description": "Build pre-check result"
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment parameters",
      "properties": {
        "estimated_gas": {
          "type": "integer",
          "description": "Estimated Soroban resource instructions"
        },
        "source_account": {
          "type": "string",
          "description": "Identity/account that will deploy"
        },
        "init_required": {
          "type": "boolean",
          "description": "Whether contract requires initialization after deployment"
        }
      }
    },
    "safety": {
      "type": "object",
      "description": "Safety checks and warnings",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "requires_approval", "blocked"],
          "description": "Safety check status"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of safety warnings"
        }
      }
    },
    "validation": {
      "type": "object",
      "description": "Pre-deployment validation results",
      "properties": {
        "contract_exists": {
          "type": "boolean"
        },
        "wasm_available": {
          "type": "boolean"
        },
        "dependencies_met": {
          "type": "boolean"
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Summary for multi-contract plans (--all mode)",
      "properties": {
        "total_estimated_gas": {
          "type": "integer"
        },
        "estimated_total_cost_xlm": {
          "type": "number"
        },
        "builds_needed": {
          "type": "integer"
        },
        "wasm_available": {
          "type": "integer"
        },
        "wasm_missing": {
          "type": "integer"
        },
        "safety_warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "estimated_cost_xlm": {
      "type": "number",
      "description": "Estimated deployment cost in XLM"
    }
  },
  "$defs": {
    "deployment_step": {
      "type": "object",
      "required": ["order", "name", "wasm_path", "wasm_available", "estimated_gas"],
      "properties": {
        "order": {
          "type": "integer",
          "description": "Deployment order (1-indexed)"
        },
        "name": {
          "type": "string",
          "description": "Contract name"
        },
        "wasm_path": {
          "type": "string",
          "description": "Relative path to WASM artifact"
        },
        "wasm_available": {
          "type": "boolean",
          "description": "Whether the WASM file exists"
        },
        "wasm_size_bytes": {
          "type": ["integer", "null"],
          "description": "Size of WASM file in bytes"
        },
        "estimated_gas": {
          "type": "integer",
          "description": "Estimated Soroban instructions"
        },
        "estimated_cost_xlm": {
          "type": "number",
          "description": "Estimated cost in XLM"
        }
      }
    }
  }
}
